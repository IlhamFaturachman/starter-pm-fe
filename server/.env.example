# SMTP / ZeptoMail configuration
# Required — ZeptoMail SMTP API token
SMTP_PASS=
# Required — sender address for outgoing emails
SMTP_FROM=noreply@yourdomain.com

# JWT secret (used by auth routes)
JWT_SECRET=change_me_to_a_random_string

# PostgreSQL (Sequelize)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=starter_pm
DB_USER=postgres
DB_PASSWORD=postgres
