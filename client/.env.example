# Client environment template.
# Copy this to `.env.local` and adjust if your backend runs elsewhere.
# These are read by client/src/config/env.ts.

# Local BE
# VITE_API_URL=http://localhost:3000/api
# VITE_SOCKET_URL=http://localhost:3000

# Deployed BE (spm)
VITE_API_URL=https://spm.liamnevalackin.my.id/api
VITE_SOCKET_URL=https://spm.liamnevalackin.my.id

# Dev only: mock auth (default true if unset). false = hit real BE.
VITE_USE_MOCK=false
